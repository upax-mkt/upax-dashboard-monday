# ═══════════════════════════════════════════════════════════
# UPAX Dashboard Monday — Variables de Entorno
# Copiar a .env.local para desarrollo local
# En Vercel: Settings > Environment Variables
# ═══════════════════════════════════════════════════════════

# Monday.com API — obtener en monday.com > Avatar > Developers > My Access Tokens
MONDAY_API_KEY=
# Board ID — el numero en la URL al abrir el board (default: 18044324200)
MONDAY_BOARD_ID=18044324200

# Google Sheets — Service Account JSON para leer datos GDD/Forecast
# Crear en Google Cloud Console > IAM > Service Accounts > Keys > JSON
# Pegar el JSON completo como valor (con las llaves {})
GOOGLE_SERVICE_ACCOUNT_JSON=
# ID del spreadsheet de Forecast/GDD (el valor entre /d/ y /edit en la URL)
SHEETS_GDD_SPREADSHEET_ID=
# Nombre de la pestaña con KPIs semanales (default: KPIs_Weekly)
SHEETS_GDD_TAB_NAME=KPIs_Weekly

# HubSpot — Private App token para consultar MQLs por origen
# Crear en HubSpot > Settings > Integrations > Private Apps > Create
# Scopes necesarios: crm.objects.contacts.read
# IMPORTANTE: el codigo lee HUBSPOT_PRIVATE_APP_TOKEN (no HUBSPOT_TOKEN)
HUBSPOT_PRIVATE_APP_TOKEN=

# Slack — Bot token para enviar minutas al canal
# Crear en api.slack.com > Your Apps > OAuth & Permissions
SLACK_BOT_TOKEN=
SLACK_CHANNEL=C081Z8R4ZH9

# Vercel KV (Upstash) — se configura automaticamente al vincular KV store en Vercel
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Password para Basic Auth del dashboard
DASHBOARD_PASSWORD=

# API Secret — protege TODAS las rutas API (GET y POST)
# Generar un valor aleatorio seguro: openssl rand -hex 32
# Debe ser el MISMO valor en API_SECRET y NEXT_PUBLIC_API_SECRET
API_SECRET=
NEXT_PUBLIC_API_SECRET=

# CRON_SECRET — protege los endpoints de cron y backfill
# En Vercel se configura automaticamente con Vercel Cron
CRON_SECRET=
